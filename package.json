{
  "name": "supa-clicker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
	"scripts": {
  	"dev": "open-cli http://localhost:3000 && dotenv -- pnpm --filter=@clicker/* --recursive run dev",
    "build:all": "dotenv -- pnpm --filter=@clicker/* --recursive run build",

    "start:www": "pnpm --filter=@clicker/www run start",
    "start:socket": "pnpm --filter=@clicker/socket run start",

    "build:www": "dotenv -- pnpm --filter=@clicker/www run build",
    "build:socket": "pnpm --filter=@clicker/socket run build"
  },
  "dependencies": {
  	"dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.1",
    "open-cli": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}